name: Playwright E2E Tests

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

jobs:
  test:
    timeout-minutes: 60
    runs-on: ubuntu-latest
    
    services:
      # MySQL for backend
      mysql:
        image: mysql:8.0
        env:
          MYSQL_ROOT_PASSWORD: root
          MYSQL_DATABASE: tedx_db
        ports:
          - 3306:3306
        options: >-
          --health-cmd="mysqladmin ping"
          --health-interval=10s
          --health-timeout=5s
          --health-retries=3

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: 'npm'
          cache-dependency-path: web-client/package-lock.json

      # Backend setup
      - name: Install backend dependencies
        working-directory: backend
        run: npm ci

      - name: Setup backend database
        working-directory: backend
        env:
          DATABASE_URL: mysql://root:root@localhost:3306/tedx_db
        run: |
          npx prisma migrate deploy
          npx prisma db seed

      - name: Start backend server
        working-directory: backend
        env:
          DATABASE_URL: mysql://root:root@localhost:3306/tedx_db
          PORT: 4000
        run: |
          npm run build
          npm start &
          sleep 10

      # Frontend setup
      - name: Install frontend dependencies
        working-directory: web-client
        run: npm ci

      - name: Install Playwright Browsers
        working-directory: web-client
        run: npx playwright install --with-deps chromium

      - name: Build frontend
        working-directory: web-client
        env:
          NEXT_PUBLIC_API_URL: http://localhost:4000/api
        run: npm run build

      - name: Start frontend server
        working-directory: web-client
        env:
          NEXT_PUBLIC_API_URL: http://localhost:4000/api
        run: |
          npm start &
          sleep 10

      # Run tests
      - name: Run Playwright tests
        working-directory: web-client
        env:
          NEXT_PUBLIC_API_URL: http://localhost:4000/api
        run: npm run test:e2e

      # Upload results
      - name: Upload Playwright Report
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: playwright-report
          path: web-client/playwright-report/
          retention-days: 30

      - name: Upload test results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: test-results
          path: web-client/test-results/
          retention-days: 30

  # Optional: Deploy preview
  deploy-preview:
    needs: test
    if: github.event_name == 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - name: Deploy to Vercel Preview
        run: echo "Deploy preview here"
