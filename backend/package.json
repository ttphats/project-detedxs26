{
  "name": "tedx-backend",
  "version": "1.0.0",
  "description": "TEDx Ticketing Platform Backend API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && pm2 restart ecosystem.config.js --env production",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop tedx-backend",
    "pm2:restart": "pm2 restart tedx-backend",
    "pm2:logs": "pm2 logs tedx-backend",
    "pm2:status": "pm2 status",
    "docker:build": "docker build -t tedx-backend .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^9.1.1",
    "@prisma/client": "^6.19.2",
    "@types/qrcode": "^1.5.6",
    "@upstash/redis": "^1.34.3",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.4",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
