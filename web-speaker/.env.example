# Database
DATABASE_URL="mysql://user:password@localhost:3306/tedx"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"
JWT_EXPIRES_IN="7d"

# Redis (Optional)
REDIS_URL=""
