# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3003"
NEXT_PUBLIC_CLIENT_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Seat Lock
SEAT_LOCK_TTL="300"

# Rate Limiting
RATE_LIMIT_MAX="100"
